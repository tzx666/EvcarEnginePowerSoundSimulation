<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/sensorStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="\u52a0\u901f\u5ea6\u4f20\u611f\u5668 + \u58f0\u6d6a\u5408\u6210\u5668"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="\u524d\u7aef\u5b8c\u6574\u7b97\u6cd5\u94fe + \u5b9e\u65f6\u5f15\u64ce\u58f0"
            android:textColor="#888"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u96f6\u767e\u65f6\u95f4 (s)" android:textSize="15sp" />
            <EditText android:id="@+id/zeroToHundredInput" android:layout_width="100dp" android:layout_height="wrap_content" android:hint="7.5" android:inputType="numberDecimal" android:maxLines="1" android:textSize="15sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="#ddd" />

        <!-- Engine Sound Section -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="\u5f15\u64ce\u58f0\u6d6a" android:textSize="15sp" android:textStyle="bold" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u542f\u7528\u58f0\u6d6a" android:textSize="14sp" />
            <Switch android:id="@+id/soundSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <RadioGroup android:id="@+id/styleGroup" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
            <RadioButton android:id="@+id/styleSport" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sport" android:textSize="13sp" />
            <RadioButton android:id="@+id/styleComfort" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Comfort" android:textSize="13sp" />
            <RadioButton android:id="@+id/styleScifi" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sci-Fi" android:textSize="13sp" />
        </RadioGroup>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="\u97f3\u91cf" android:textSize="13sp" android:layout_marginEnd="8dp" />
            <SeekBar android:id="@+id/intensitySeekBar" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="100" android:progress="65" />
            <TextView android:id="@+id/intensityValue" android:layout_width="40dp" android:layout_height="wrap_content" android:text="65%" android:textSize="13sp" android:gravity="end" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="16dp" android:background="#ddd" />

        <!-- Linear acceleration section -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="\u7ebf\u6027\u52a0\u901f\u5ea6\uff08\u91cd\u529b\u5df2\u5254\u9664\uff09" android:textSize="15sp" android:textStyle="bold" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u7ebf\u6027 X" android:textSize="14sp" />
            <TextView android:id="@+id/accelX" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.000" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u7ebf\u6027 Y" android:textSize="14sp" />
            <TextView android:id="@+id/accelY" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.000" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u7ebf\u6027 Z" android:textSize="14sp" />
            <TextView android:id="@+id/accelZ" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.000" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="#ddd" />

        <!-- Algorithm chain -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="\u524d\u7aef\u7b97\u6cd5\u94fe\u63a8\u6f14" android:textSize="15sp" android:textStyle="bold" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u6c34\u5e73\u5408\u52a0\u901f\u5ea6" android:textSize="14sp" />
            <TextView android:id="@+id/horizontalAccel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.000 m/s\u00b2" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u5e73\u6ed1\u5408\u52a0\u901f\u5ea6" android:textSize="13sp" />
            <TextView android:id="@+id/smoothAccel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.000 m/s\u00b2" android:textSize="13sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u96f6\u767e\u65f6\u95f4" android:textSize="14sp" />
            <TextView android:id="@+id/zeroToHundredDisplay" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7.5 s" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u6ee1\u7535\u95e8\u52a0\u901f\u5ea6" android:textSize="14sp" />
            <TextView android:id="@+id/fullThrottleAccelDisplay" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3.704 m/s\u00b2" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u539f\u59cb\u62df\u5408\u6cb9\u95e8" android:textSize="14sp" />
            <TextView android:id="@+id/estimatedThrottle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0%" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u5e73\u6ed1\u6cb9\u95e8" android:textSize="13sp" />
            <TextView android:id="@+id/smoothThrottle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0%" android:textSize="13sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Debug 200%\u589e\u76ca" android:textSize="14sp" />
            <TextView android:id="@+id/debugThrottle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0%" android:textSize="14sp" android:textStyle="bold" android:textColor="#d9534f" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="#ddd" />

        <!-- Instruments -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="\u6a21\u62df\u4eea\u8868" android:textSize="15sp" android:textStyle="bold" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u4f30\u7b97\u901f\u5ea6" android:textSize="14sp" />
            <TextView android:id="@+id/speedValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0 km/h" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u4f30\u7b97 RPM" android:textSize="14sp" />
            <TextView android:id="@+id/rpmValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="900" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="\u6863\u4f4d" android:textSize="14sp" />
            <TextView android:id="@+id/gearValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="N" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:lineSpacingExtra="4dp" android:text="\u5b8c\u6574\u94fe\u8def\uff1a\u4f20\u611f\u5668\u2192\u4f4e\u901a\u6ee4\u6ce2\u5254\u91cd\u529b\u2192\u5408\u52a0\u901f\u5ea6\u2192\u62df\u5408\u6cb9\u95e8\u2192\u5e73\u6ed1\u5316\u2192RPM/\u901f\u5ea6/\u6863\u4f4d\u63a8\u7b97\u2192CarTelemetry\u2192\u5f15\u64ce\u58f0\u5408\u6210\u5668\u2192\u97f3\u9891\u8f93\u51fa\u3002\n\u6253\u5f00\u58f0\u6d6a\u5f00\u5173\uff0c\u6643\u52a8\u624b\u673a\u5373\u53ef\u542c\u5230\u5f15\u64ce\u58f0\u3002" android:textColor="#888" android:textSize="12sp" />

    </LinearLayout>
</ScrollView>